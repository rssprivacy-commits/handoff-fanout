#!/usr/bin/env bash
# pre-push — delivery-audit machine gate (hf pilot / 2026-06-12 owner-approved B+A design,
# dual-brain GREEN).
#
# The iron rule「中枢审派出会话交付必加外双脑」had no machine enforcement: an unaudited
# worker delivery could be merged and pushed to main on coordinator good will alone.
# This hook blocks pushing NEW commits to the protected branch (main) unless machine
# audit evidence (the dual-brain runner's *.evidence.json sidecar under
# $HANDOFF_HOME/<project>/audits/) matches the pushed range — by reviewed head SHA, or
# by `git patch-id --stable` + identical changed-file set (tolerates cherry-pick/rebase).
# RED verdicts fail unless the owner ran the tty-gated `handoff audit-override`.
#
# All policy lives in `handoff audit-check` (src/handoff_fanout/audit_evidence.py) —
# this script only slices the pushed ref updates. Fail-closed: if the handoff CLI is
# unavailable the push is refused (last-resort emergency paths are documented in the
# owner runbook, dharmaxis project-files/handoff/audit-gate-runbook.md — deliberately
# not here, so AI sessions don't learn to self-bypass).
#
# stdin: one line per ref being pushed: <local_ref> <local_sha> <remote_ref> <remote_sha>
set -u

PROTECTED="refs/heads/main"
ZERO=0000000000000000000000000000000000000000
# git's well-known empty-tree object — diff base when the remote ref doesn't exist yet.
EMPTY_TREE=4b825dc642cb6eb9a060e54bf8d69288fbee4904
HBIN="${HANDOFF_BIN:-handoff}"

repo="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -n "$repo" ] || exit 0

status=0
while read -r _local_ref local_sha remote_ref remote_sha; do
    [ "$remote_ref" = "$PROTECTED" ] || continue
    [ "$local_sha" = "$ZERO" ] && continue   # ref deletion publishes nothing new
    base="$remote_sha"
    [ "$base" = "$ZERO" ] && base="$EMPTY_TREE"
    if [ "$base" != "$EMPTY_TREE" ]; then
        new_count="$(git rev-list --count "$base..$local_sha" 2>/dev/null || echo 1)"
        [ "$new_count" = "0" ] && continue   # nothing new being published
    fi
    if ! command -v "$HBIN" >/dev/null 2>&1; then
        # NB: ${remote_ref} braces are load-bearing — under a C locale bash would parse
        # the first byte of the following CJK char into the variable name (unbound var).
        echo "❌ handoff pre-push audit gate: '$HBIN' CLI 不可用 — fail-closed 拒推 ${remote_ref}。" >&2
        echo "   补救路径见 owner runbook: audit-gate-runbook.md（dharmaxis project-files/handoff/）。" >&2
        status=1
        continue
    fi
    if ! "$HBIN" audit-check --repo "$repo" --range "$base..$local_sha"; then
        echo "" >&2
        echo "❌ handoff pre-push audit gate: $remote_ref 被推区间 ${base:0:12}..${local_sha:0:12} 未通过审计闸 — 拒推。" >&2
        status=1
    fi
done

exit $status
